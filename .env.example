# Telegram (required for the full server, polling bot, and webhook modes;
# the Smithery deployment takes credentials per session instead)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Webhook mode (optional)
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook
WEBHOOK_SECRET=change-me

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
MCP_PORT=8001

# Logging
DEBUG=false
LOG_LEVEL=INFO
