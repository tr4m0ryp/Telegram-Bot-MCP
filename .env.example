# Telegram (required for the full server, polling bot, webhook, and launch gate;
# the Smithery deployment takes credentials per session instead)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Launch gate — the operator identity (the ONLY user whose taps are honored, and
# the chat notifications go to). Get the user id from @userinfobot.
OPERATOR_TELEGRAM_USER_ID=123456789
OPERATOR_CHAT_ID=123456789

# Webhook registration
TELEGRAM_WEBHOOK_URL=https://telegram-mcp.frogbytes.xyz/telegram/webhook
WEBHOOK_SECRET=change-me
PUBLIC_URL=https://telegram-mcp.frogbytes.xyz

# MCP auth (bearer for Claude Code). Leave MCP_OAUTH_PROVIDER empty for bearer;
# set it (e.g. "workos") only once an OAuth provider is wired for claude.ai.
# With neither a bearer nor a provider, the service refuses to start (fail-closed)
# unless MCP_ALLOW_UNAUTHENTICATED=true is set — local development only.
MCP_BEARER_TOKEN=generate_with_openssl_rand_hex_32
MCP_OAUTH_PROVIDER=
MCP_ALLOW_UNAUTHENTICATED=false

# Launch-token store (reuse the enrichment Postgres DSN).
# A standard postgresql:// connection string with user, password, host, port, db.
DATABASE_URL=

# Internal mint guard. Leave UNSET for same-process minting (default): the
# /launch-tokens HTTP route is then not mounted at all. Set it only to expose an
# out-of-process mint endpoint guarded by this secret.
TOKEN_MINT_SECRET=

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
MCP_PORT=8001

# Logging
DEBUG=false
LOG_LEVEL=INFO
